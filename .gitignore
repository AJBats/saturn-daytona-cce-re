# Build artifacts
build/*
!build/save_states/
!build/save_states/*.mc0
reimpl/build/
*.o
*.elf
*.map
*.bin
*.BIN

# Disc images (large, copyrighted) — keep the folder, ignore contents
external_resources/*
!external_resources/.gitkeep
*.cue
*.bin
*.iso
*.img
*.mds
*.mdf

# Toolchain binaries and build temp
tools/sh-elf/
.setup-tmp/

# Archived one-off tools (kept locally for reference)
tools/archive/

# Claude session memory (auto-generated, not tracked)
.claude/memory/

# Ghidra reference (generated, large)
ghidra_reference/

# Python bytecode cache
__pycache__/
*.pyc

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
*.swp
*~
